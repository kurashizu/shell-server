# =============================================================================
# Shell Server - Configuration file
# Uncomment a variable to override its default value.
# Restart the server after changes:  make dev  or  make run
# =============================================================================

# ---- Network ----------------------------------------------------------------
# SHELL_SERVER_HOST=127.0.0.1
# SHELL_SERVER_PORT=8080

# ---- Workspace --------------------------------------------------------------
# Sandbox directory where all commands run (cwd is forced here)
# SHELL_SERVER_WORKSPACE_PATH=/tmp/shell-server-workspace

# ---- Execution limits -------------------------------------------------------
# Default command timeout in seconds (clients can override via timeout_secs)
# SHELL_SERVER_DEFAULT_TIMEOUT=30
# Maximum allowed timeout (clients cannot exceed this)
# SHELL_SERVER_MAX_TIMEOUT=300
# Max bytes per stdout / stderr stream; excess is truncated (truncated=true)
# SHELL_SERVER_MAX_OUTPUT_SIZE=1048576

# ---- Security ---------------------------------------------------------------
# Command whitelist (empty = allow everything)
# Format 1 (comma-separated):  SHELL_SERVER_ALLOWED_COMMANDS=echo,ls,git
# Format 2 (JSON array):       SHELL_SERVER_ALLOWED_COMMANDS=["echo","ls","git"]
# SHELL_SERVER_ALLOWED_COMMANDS=
# Bearer token authentication (empty = no auth required)
# Clients must send:  Authorization: Bearer <token>
# SHELL_SERVER_AUTH_TOKEN=
